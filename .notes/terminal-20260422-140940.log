START: Read VS Code settings and Augment extension config
=== VS Code settings.json ===
{
  "extensions.autoUpdate": false,

  "workbench.settings.applyToAllProfiles": [
    "augment.completions.enableChatInputCompletions"
  ],

  "augment.completions.enableChatInputCompletions": false,

  "chat.extensionUnification.enabled": false,
  "chat.disableAIFeatures": false,

  "github.copilot.enable": false,
  "github.copilot.inlineSuggest.enable": false,

  "git.enabled": true,
  "git.autofetch": false,

  "vscode-augment.featureFlags.enableRemoteAgents": false,

  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.shellIntegration.enabled": true,

  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "/bin/bash",
      "args": [
        "--noprofile"
      ]
    }
  },

  "files.watcherExclude": {
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.cache/**": true,
    "**/dist/**": true
  },

  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true
  },

  "telemetry.telemetryLevel": "off",
  "workbench.enableExperiments": false,

  "watchdog.monitorInterval": 5000,
  "watchdog.maxTerminals": 10,
  "watchdog.autoCleanup": true,
  "watchdog.augmentIntegration": true,
  "watchdog.notificationsEnabled": true,
  "watchdog.logToNotes": true,
  "watchdog.baselineTracking": true,

  "workbench.colorTheme": "Dark Modern"
}
